<UserControl x:Class="NEFAB.Views.SupplierView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NEFAB.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <Grid>
        <Rectangle HorizontalAlignment="Center" Height="100" Stroke="Black" Fill="#144e8c" VerticalAlignment="Top" Width="900"/>

        <Label Content="Leverandør" HorizontalAlignment="Center" Margin="0,22,0,0" VerticalAlignment="Top" Height="56" Width="201" FontSize="36" FontWeight="Bold" Foreground="White"/>
        <Button Content="Tilbage" Command="{Binding NavigateToHomeViewCommand}" HorizontalAlignment="Left" Margin="35,365,0,0" VerticalAlignment="Top" Width="88" Height="35" FontSize="15" Background="#FF8CB3DB"/>
        <Label Content="opret:" HorizontalAlignment="Left" Margin="35,110,0,0" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
        <Label Content="nyt navn" HorizontalAlignment="Left" Margin="35,145,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="NewSupplierName_tb" Text="{Binding SelectedSupplier.SupplierName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"  HorizontalAlignment="Left" Margin="120,145,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="120"/>
        <TextBox  HorizontalAlignment="Left" Margin="505,180,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Button x:Name="NewSupplierSave_btn" Command="{Binding SaveSupplierCommand}" Content="Gem" HorizontalAlignment="Left" Margin="245,158,0,0" VerticalAlignment="Top"/>
        <Button Content="Gem" HorizontalAlignment="Left" Margin="630,189,0,0" VerticalAlignment="Top"/>
        <Label Content="rediger:" HorizontalAlignment="Left" Margin="420,110,0,0" VerticalAlignment="Top" FontSize="14" FontWeight="Bold"/>
        <Label Content="navn" HorizontalAlignment="Left" Margin="420,145,0,0" VerticalAlignment="Top"/>
        <Label Content="nyt navn" HorizontalAlignment="Left" Margin="420,180,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="505,145,0,0" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Top" Width="120"/>
        <Image HorizontalAlignment="Left" Height="60" Margin="10,10,0,0" VerticalAlignment="Top" Width="150" Source="/images/nefab white.png"/>

    </Grid>
</UserControl>
