<UserControl x:Class="NEFAB.Views.PackageStatusCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NEFAB.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <Grid>
        <Rectangle HorizontalAlignment="Center" Height="100" Stroke="Black" Fill="#144e8c" VerticalAlignment="Top" Width="900"/>
        <Label Content="Tilføj pakke-status" HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" Width="381" FontSize="36" FontWeight="Bold" Foreground="White"/>
        <Image HorizontalAlignment="Left" Height="60" Margin="10,10,0,0" VerticalAlignment="Top" Width="150" Source="/images/nefab white.png"/>


        <Label Content="Container Nummer" HorizontalAlignment="Left" Margin="37,125,0,0" VerticalAlignment="Top"/>
        <Button Content="Tilbage" Command="{Binding NavigateToPackageViewCommand}" HorizontalAlignment="Left" Margin="34,378,0,0" VerticalAlignment="Top" Height="35" Width="88"/>
        <Label Content="Leverandør" HorizontalAlignment="Left" Margin="37,174,0,0" VerticalAlignment="Top"/>
        <Label Content="Indholdsmængde" HorizontalAlignment="Left" Margin="37,222,0,0" VerticalAlignment="Top"/>
        <Label Content="Antal pakker" HorizontalAlignment="Left" Margin="37,270,0,0" VerticalAlignment="Top"/>
        <Label Content="Vægt" HorizontalAlignment="Left" Margin="37,320,0,0" VerticalAlignment="Top"/>
        <Label Content="Længde" HorizontalAlignment="Left" Margin="363,125,0,0" VerticalAlignment="Top"/>
        <Label Content="Bredde" HorizontalAlignment="Left" Margin="363,174,0,0" VerticalAlignment="Top"/>
        <Label Content="Højde" HorizontalAlignment="Left" Margin="369,222,0,0" VerticalAlignment="Top"/>
        <Label Content="Projekt nummer" HorizontalAlignment="Left" Margin="342,270,0,0" VerticalAlignment="Top"/>
        <Label Content="Projekt produkt nummer" HorizontalAlignment="Left" Margin="297,320,0,0" VerticalAlignment="Top"/>
        <Label Content="Kommentar: " HorizontalAlignment="Left" Margin="608,243,0,0" VerticalAlignment="Top"/>
       <Label Content="Status" HorizontalAlignment="Left" Margin="647,160,0,0" VerticalAlignment="Top"/>


        <TextBox x:Name="txtUpdateContainerNo" HorizontalAlignment="Left" Margin="150,129,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.ContainerNo, UpdateSourceTrigger=PropertyChanged, Mode =OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateSupplier" HorizontalAlignment="Left" Margin="150,178,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.SupplierName, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateInnerQuantaty" HorizontalAlignment="Left" Margin="150,226,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.InnerQuantity, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateAmount" HorizontalAlignment="Left" Margin="150,274,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.Amount, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateWeight" HorizontalAlignment="Left" Margin="150,324,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageWeight, UpdateSourceTrigger=PropertyChanged, Mode=Oneway}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateLength" HorizontalAlignment="Left" Margin="442,129,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageLength, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateWidth" HorizontalAlignment="Left" Margin="440,178,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageWidth, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateHeight" HorizontalAlignment="Left" Margin="442,226,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageHeight, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateProjectNo" HorizontalAlignment="Left" Margin="442,274,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.ProjectNo, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox x:Name="txtUpdateProjectItemNo" HorizontalAlignment="Left" Margin="442,324,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.ProjectItemNo, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}" VerticalAlignment="Top" Width="120" IsEnabled="False"/>
        <TextBox HorizontalAlignment="Left" Margin="608,274,0,0" TextWrapping="Wrap" Text="{Binding SelectedStatus.Comment, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" VerticalAlignment="Top" Width="233" Height="88"/>
        <Button Content="Gem ny status" Command="{Binding AddStatusPackageCommand}" HorizontalAlignment="Left" Margin="781,384,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.152,0.71" FontSize="14"/>


        <ComboBox SelectedItem="{Binding SelectedStatus.Status, Mode=TwoWay}" ItemsSource="{Binding AvailableStatusTypes}" HorizontalAlignment="Left" Margin="721,165,0,0" VerticalAlignment="Top" Width="120"/>
        <Label Content="MedarbejderID:" HorizontalAlignment="Left" Margin="597,125,0,0" VerticalAlignment="Top"/>
        <TextBox HorizontalAlignment="Left" Margin="724,129,0,0" TextWrapping="Wrap" Text="{Binding SelectedStatus.EmployeeId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" Width="120"/>




    </Grid>
</UserControl>
