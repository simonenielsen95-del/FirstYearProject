<UserControl x:Class="NEFAB.Views.PackageView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NEFAB.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <Grid>
        <Button Content="Tilbage" Command="{Binding NavigateToHomeViewCommand}" HorizontalAlignment="Left" Margin="34,380,0,0" Width="88" Height="34" VerticalAlignment="Top"/>
        <Button Content="Opret ny pakke" Command="{Binding NavigateToPackageCreateViewCommand}" HorizontalAlignment="Left" Margin="626,128,0,0" VerticalAlignment="Top" Width="120" Height="29"/>
        <Button Content="Rediger pakke" Command="{Binding NavigateToPackageEditViewCommand}" HorizontalAlignment="Left" Margin="488,373,0,0" VerticalAlignment="Top" Width="80" Height="24"/>
        <Button Content="Slet pakke" Command="{Binding NavigateToPackageRemoveViewCommand}" HorizontalAlignment="Left" Margin="626,368,0,0" VerticalAlignment="Top" Width="80" Height="24"/>


        <Rectangle HorizontalAlignment="Center" Height="100" Stroke="Black" Fill="#144e8c" VerticalAlignment="Top" Width="900"/>
        <Image HorizontalAlignment="Left" Height="56" VerticalAlignment="Top" Width="1350" Source="/images/nefab white.png" Margin="10,24,0,0"/>

        <Label Content="Find pakke:" HorizontalAlignment="Left" Margin="46,111,0,0" VerticalAlignment="Top" FontSize="18"/>
        <Label Content="Pakke oversigt" HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" FontSize="36" Foreground="White" FontWeight="Bold"/>


        <ListBox x:Name ="PackageList" SelectedItem="{Binding SelectedPackage, Mode=TwoWay}" ItemsSource="{Binding OCPackages, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" Margin="97,201,94,137">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.Template>
                <ControlTemplate TargetType="ListBox">
                    <Border BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                        <ScrollViewer>
                            <StackPanel>
                                <Grid Background="#144e8c">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Amount" Grid.Column="0" FontWeight="Bold" Margin="5" Foreground="White"/>
                                    <TextBlock Text="Vægt" Grid.Column="1" FontWeight="Bold" Margin="5" Foreground="White"/>
                                    <TextBlock Text="Project No" Grid.Column="2" FontWeight="Bold" Margin="5" Foreground="White"/>
                                    <TextBlock Text="Item No" Grid.Column="3" FontWeight="Bold" Margin="5" Foreground="White"/>
                                    <TextBlock Text="Leverandør" Grid.Column="4" FontWeight="Bold" Margin="5" Foreground="White"/>
                                    <TextBlock Text="Inner Qty" Grid.Column="5" FontWeight="Bold" Margin="5" Foreground="White"/>
                                </Grid>
                                <ItemsPresenter />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </ControlTemplate>
            </ListBox.Template>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="3*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding Amount}" Grid.Column="0" Margin="5"/>
                        <TextBlock Text="{Binding PackageWeight}" Grid.Column="1" Margin="5"/>
                        <TextBlock Text="{Binding ProjectNo}" Grid.Column="2" Margin="5"/>
                        <TextBlock Text="{Binding ProjectItemNo}" Grid.Column="3" Margin="5"/>
                        <TextBlock Text="{Binding SupplierName}" Grid.Column="4" Margin="5"/>
                        <TextBlock Text="{Binding InnerQuantity}" Grid.Column="5" Margin="5"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBox HorizontalAlignment="Left" Margin="162,151,0,0" TextWrapping="Wrap" Text="{Binding Container.ContainerNo, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" VerticalAlignment="Top" Width="120" RenderTransformOrigin="0.462,-0.139"/>
        <TextBlock HorizontalAlignment="Left" Margin="46,151,0,0" TextWrapping="Wrap" VerticalAlignment="Top"><Run Text="Tast et Container No "/><LineBreak/><Run Text="og vælg en pakke"/></TextBlock>
        <Label Content="Samlet antal InnerQuantity" HorizontalAlignment="Left" Margin="222,414,0,0" VerticalAlignment="Top"/>
        <Button Content="Søg" Command="{Binding SearchPackages}" HorizontalAlignment="Left" Margin="321,160,0,0" VerticalAlignment="Top"/>

    </Grid>
</UserControl>

