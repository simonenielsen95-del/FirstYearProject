<UserControl x:Class="NEFAB.Views.PackageCreateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:NEFAB.Views"
             mc:Ignorable="d" 
             d:DesignHeight="500" d:DesignWidth="900">
    <Grid>

        <Rectangle HorizontalAlignment="Center" Height="100" Stroke="Black" Fill="#144e8c" VerticalAlignment="Top" Width="900"/>
        <Image HorizontalAlignment="Left" Height="98" Margin="680,185,0,0" VerticalAlignment="Top" Width="177"/>

        <Label Content="Opret Pakke" HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" Width="218" FontSize="36" FontWeight="Bold" Foreground="White"/>
        <Label Content="Container nummer:" HorizontalAlignment="Left" Margin="20,147,0,0" VerticalAlignment="Top"/>
        <Button Content="Tilbage" Command="{Binding NavigateToPackageViewCommand}" HorizontalAlignment="Left" Margin="32,391,0,0" VerticalAlignment="Top" Height="35" Width="88"/>
        <Label Content="Leverandør:" HorizontalAlignment="Left" Margin="24,191,0,0" VerticalAlignment="Top"/>
        <Label Content="Indholdsmængde:" HorizontalAlignment="Left" Margin="20,232,0,0" VerticalAlignment="Top"/>
        <Label Content="Antal pakker:" HorizontalAlignment="Left" Margin="20,279,0,0" VerticalAlignment="Top"/>
        <Label Content="Vægt:" HorizontalAlignment="Left" Margin="20,326,0,0" VerticalAlignment="Top"/>
        <Label Content="Længde:" HorizontalAlignment="Left" Margin="305,151,0,0" VerticalAlignment="Top"/>
        <Label Content="Bredde:" HorizontalAlignment="Left" Margin="305,195,0,0" VerticalAlignment="Top"/>
        <Label Content="Højde:" HorizontalAlignment="Left" Margin="305,241,0,0" VerticalAlignment="Top"/>
        <Label Content="Projekt nummer:" HorizontalAlignment="Left" Margin="307,283,0,0" VerticalAlignment="Top"/>
        <Label Content="Projekt produkt nummer:" HorizontalAlignment="Left" Margin="305,330,0,0" VerticalAlignment="Top"/>
        <Label Content="Billed:" HorizontalAlignment="Left" Margin="627,151,0,0" VerticalAlignment="Top"/>
        <Label Content="Commentar:" HorizontalAlignment="Left" Margin="627,287,0,0" VerticalAlignment="Top"/>


        <TextBox x:Name="txtContainerNo" HorizontalAlignment="Left" Margin="145,151,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.ContainerNo, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtSupplier" HorizontalAlignment="Left" Margin="145,195,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.SupplierName, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtInnerQuantaty" HorizontalAlignment="Left" Margin="145,236,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.InnerQuantity, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtAmount" HorizontalAlignment="Left" Margin="145,287,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.Amount, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtWeight" HorizontalAlignment="Left" Margin="145,334,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageWeight, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtLenth" HorizontalAlignment="Left" Margin="465,155,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageLength, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtWith" HorizontalAlignment="Left" Margin="465,199,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageWidth, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtHeight" HorizontalAlignment="Left" Margin="465,244,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.PackageHeight, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtProjectNo" HorizontalAlignment="Left" Margin="465,286,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.ProjectNo, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtProjectItemNo" HorizontalAlignment="Left" Margin="465,334,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.ProjectItemNo, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox x:Name="txtImage" HorizontalAlignment="Left" Margin="685,151,0,0" TextWrapping="Wrap" Text="{Binding SelectedImage.path?, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="120" />
        <TextBox HorizontalAlignment="Left" Margin="707,300,0,0" TextWrapping="Wrap" Text="{Binding SelectedPackage.Comment, UpdateSourceTrigger=PropertyChanged, Mode =TwoWay}" VerticalAlignment="Top" Width="153" Height="159"/>

        <Button x:Name="btnCreateNewPackage" Content="OPRET" Command="{Binding CreateNewPackageCommand}" HorizontalAlignment="Left" Margin="546,411,0,0" VerticalAlignment="Top" RenderTransformOrigin="0.08,0.927"/>
        <Image HorizontalAlignment="Left" Height="60" Margin="10,10,0,0" VerticalAlignment="Top" Width="150" Source="/images/nefab white.png"/>



    </Grid>
</UserControl>
